{
  "output_dir": "outputs/rcan2d_supervised",
  "model": {
    "name": "rcan2d",
    "in_channels": 1,
    "out_channels": 1,
    "num_features": 32,
    "num_groups": 5,
    "num_blocks": 5,
    "reduction": 8,
    "bn": false,
    "residual_scale": 1.0,
    "final_activation": "none"
  },
  "data": {
    "normalization_mode": "input_scale",
    "input_scale_method": "percentile",
    "input_scale_percentile": 99.9,
    "patch_size": [
      512,
      512
    ],
    "train": {
      "manifest": "metadata/manifest.csv",
      "augment": true,
      "samples_per_epoch": 2000
    },
    "val": {
      "manifest": "validation/metadata/manifest.csv",
      "augment": false,
      "samples_per_epoch": 400
    },
    "test": {
      "manifest": "Test/metadata/manifest.csv",
      "augment": false
    }
  },
  "training": {
    "epochs": 100,
    "batch_size": 8,
    "num_workers": 4,
    "optimizer": "AdamW",
    "initial_learning_rate": 0.000025,
    "lr_scheduler": "StepLR",
    "step_size": 40,
    "gamma": 0.5,
    "weight_decay": 0.0
  }
}
