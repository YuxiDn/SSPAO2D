{
  "output_dir": "outputs/dfcan2d_fftshift_200ep",
  "model": {
    "name": "dfcan2d",
    "in_channels": 1,
    "out_channels": 1,
    "num_features": 64,
    "num_groups": 4,
    "num_blocks": 4,
    "reduction": 16,
    "final_activation": null
  },
  "data": {
    "root": "/mnt/share/dyx/Data/Data2d",
    "normalization_mode": "input_scale",
    "input_scale_method": "percentile",
    "input_scale_percentile": 99.9,
    "patch_size": [512, 512],
    "train": {
      "manifest": "metadata/manifest.csv",
      "augment": true
    },
    "val": {
      "manifest": "validation/metadata/manifest.csv",
      "augment": false,
      "samples_per_epoch": 400
    }
  },
  "training": {
    "epochs": 100,
    "batch_size": 2,
    "num_workers": 4,
    "optimizer": "Adam",
    "initial_learning_rate": 0.0001,
    "loss": "mse",
    "lr_scheduler": "ReduceLROnPlateau",
    "factor": 0.5,
    "patience": 10,
    "min_lr": 0.000004,
    "weight_decay": 0.0
  }
}
