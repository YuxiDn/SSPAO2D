{
  "output_dir": "outputs/rcan2d_supervised_v2",
  "model": {
    "name": "rcan2d",
    "in_channels": 1,
    "out_channels": 1,
    "num_features": 64,
    "num_groups": 5,
    "num_blocks": 5,
    "reduction": 8,
    "bn": false,
    "residual_scale": 1.0,
    "final_activation": "none"
  },
  "data": {
    "patch_size": [
      512,
      512
    ],
    "train": {
      "manifest": "metadata/manifest.csv",
      "augment": true,
      "samples_per_epoch": 2000
    },
    "val": {
      "manifest": "validation/metadata/manifest.csv",
      "augment": false,
      "samples_per_epoch": 400
    }
  },
  "training": {
    "epochs": 200,
    "batch_size": 2,
    "num_workers": 4,
    "optimizer": "Adam",
    "initial_learning_rate": 0.0001,
    "lr_scheduler": "CosineAnnealingLR",
    "T_max": 200,
    "min_lr": 1e-06,
    "weight_decay": 0.0
  }
}
