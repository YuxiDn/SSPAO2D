{
  "output_dir": "outputs/care2d_supervised_v2",
  "model": {
    "name": "care2d",
    "in_channels": 1,
    "out_channels": 1,
    "base_channels": 64,
    "depth": 4,
    "norm": "batch",
    "final_activation": null
  },
  "data": {
    "normalization_mode": "input_scale",
    "input_scale_method": "percentile",
    "input_scale_percentile": 99.9,
    "patch_size": [
      512,
      512
    ],
    "train": {
      "manifest": "metadata/manifest.csv",
      "augment": true,
      "samples_per_epoch": 2000
    },
    "val": {
      "manifest": "validation/metadata/manifest.csv",
      "augment": false,
      "samples_per_epoch": 400
    },
    "test": {
      "manifest": "Test/metadata/manifest.csv",
      "augment": false
    }
  },
  "training": {
    "epochs": 200,
    "batch_size": 8,
    "num_workers": 4,
    "optimizer": "Adam",
    "initial_learning_rate": 0.0001,
    "lr_scheduler": "StepLR",
    "min_lr": 1e-06,
    "weight_decay": 0.0,
    "step_size": 50,
    "gamma": 0.5
  }
}
