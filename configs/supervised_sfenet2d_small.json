{
  "output_dir": "outputs/sfenet2d_small",
  "model": {
    "name": "sfenet2d",
    "in_channels": 1,
    "out_channels": 1,
    "num_features": 32,
    "encoder_channels": 128,
    "num_groups": 2,
    "num_blocks": 4,
    "reduction": 16,
    "fft_branch": true,
    "fft": true,
    "fft_shift": false,
    "fft_forward": true,
    "unet_depth": 5,
    "num_pixel_stack_layer": 0,
    "final_activation": "relu"
  },
  "data": {
    "root": "/data/yxdeng993/data/2Dsim",
    "patch_size": [256, 256],
    "train": {
      "manifest": "metadata/manifest.csv",
      "augment": true,
      "samples_per_epoch": 64
    },
    "val": {
      "manifest": "validation/metadata/manifest.csv",
      "augment": false,
      "samples_per_epoch": 16
    }
  },
  "training": {
    "epochs": 1,
    "batch_size": 4,
    "num_workers": 4,
    "optimizer": "Adam",
    "initial_learning_rate": 0.0001,
    "lr_scheduler": "StepLR",
    "step_size": 50,
    "gamma": 0.5,
    "weight_decay": 0.0
  }
}
